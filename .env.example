# Server
PORT=3001

# Database (MySQL)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# Encryption key (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Privy Auth (https://privy.io)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# AI Provider (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Buidlr wallet address (receives ETH payments for credits)
BUIDLR_WALLET_ADDRESS=0xYourWalletAddress

# Credits pricing
CREDIT_RATE_PER_ETH=100000
CREDIT_COST_PER_1K_TOKENS=5

# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Preview domain (wildcard DNS + SSL required)
PREVIEW_DOMAIN=preview.yourdomain.com

# Blockchain
BLOCKCHAIN_NETWORK=testnet
RPC_URL_TESTNET=https://your-testnet-rpc-url
RPC_URL_MAINNET=https://your-mainnet-rpc-url

# Container lifecycle
CONTAINER_IDLE_TIMEOUT_MINUTES=30
CONTAINER_MAX_AGE_DAYS=30

# Agent pricing
AGENT_CREDIT_PER_HOUR=1
AGENT_CREDIT_PER_TX=5
